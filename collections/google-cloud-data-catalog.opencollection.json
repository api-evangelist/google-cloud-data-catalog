            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path"
              },
              {
                "name": "location",
                "value": "",
                "type": "path"
              },
              {
                "name": "entryGroupId",
                "value": "",
                "type": "path"
              },
              {
                "name": "entryId",
                "value": "",
                "type": "path"
              }
            ]
